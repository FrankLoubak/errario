{
  "expo": {
    "name": "Errário",
    "slug": "errario",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.errario.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Usado para foto de perfil",
        "NSPhotoLibraryUsageDescription": "Usado para foto de perfil"
      },
      "entitlements": {
        "com.apple.developer.in-app-payments": ["merchant.com.errario.app"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a1a2e"
      },
      "package": "com.errario.app",
      "versionCode": 1,
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#4f46e5",
          "sounds": []
        }
      ],
      [
        "expo-sqlite",
        {
          "enableFTS": true,
          "useSQLCipher": false
        }
      ]
    ],
    "scheme": "errario",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "SUBSTITUA_PELO_SEU_EAS_PROJECT_ID"
      },
      "apiUrl": {
        "development": "http://localhost:3001",
        "preview": "https://api.errario.app",
        "production": "https://api.errario.app"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/SUBSTITUA_PELO_SEU_EAS_PROJECT_ID",
      "enabled": true,
      "fallbackToCacheTimeout": 0,
      "checkAutomatically": "ON_LOAD"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
