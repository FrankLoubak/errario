# ─────────────────────────────────────────────────────────────────────────────
# Errário Backend — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o .env real no repositório
# ─────────────────────────────────────────────────────────────────────────────

# Ambiente
NODE_ENV=development
PORT=3001

# ─── Banco de Dados ──────────────────────────────────────────────────────────
# Formato: postgresql://USUARIO:SENHA@HOST:PORTA/BANCO?schema=public
DATABASE_URL=postgresql://errario_user:sua_senha_aqui@localhost:5432/errario_dev?schema=public

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT (use valores longos e aleatórios em produção) ───────────────────────
# Gere com: openssl rand -hex 64
JWT_SECRET=TROQUE_POR_VALOR_ALEATORIO_LONGO_MINIMO_32_CHARS
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=TROQUE_POR_OUTRO_VALOR_ALEATORIO_LONGO_MINIMO_32_CHARS
JWT_REFRESH_EXPIRES_IN=30d

# ─── Google OAuth ────────────────────────────────────────────────────────────
# Crie em: https://console.cloud.google.com → Credenciais
GOOGLE_CLIENT_ID=SEU_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=SEU_GOOGLE_CLIENT_SECRET
GOOGLE_CALLBACK_URL=com.errario.app:/auth/callback

# ─── SendGrid (email) ────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG.SEU_SENDGRID_API_KEY
EMAIL_FROM=noreply@errario.app

# ─── Sentry (error tracking) ─────────────────────────────────────────────────
SENTRY_DSN=https://SEU_SENTRY_DSN@sentry.io/ID

# ─── URLs ────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:3001

# ─── Segurança ───────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=10

# ─── Apple IAP (StoreKit 2) ──────────────────────────────────────────────────
APPLE_BUNDLE_ID=com.errario.app
APPLE_SHARED_SECRET=SEU_APPLE_SHARED_SECRET

# ─── Google Play Billing ─────────────────────────────────────────────────────
GOOGLE_PLAY_PACKAGE_NAME=com.errario.app
# JSON string da service account key (base64 ou path)
GOOGLE_PLAY_SERVICE_ACCOUNT_KEY=
